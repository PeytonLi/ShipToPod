[["stepper-wizard", "Build multi-step wizard with indicators and per-step validation", [["c-nav", "Next/Back buttons", 0.35], ["c-ind", "Step indicators", 0.3], ["c-val", "Validation per step", 0.35]], [["function @N@({steps}){const[s,setS]=useState(0);return <div><div>{steps[s].content}</div><button onClick={()=>setS(s-1)} disabled={s===0}>Back</button><button onClick={()=>setS(s+1)} disabled={s===steps.length-1}>Next</button></div>}", "No step indicators; no validation; no ARIA; can skip invalid steps", "function @N@({steps,onComplete}){const[s,setS]=useState(0);const[errs,setErrs]=useState({});const v=()=>{const e=steps[s].validate?.();setErrs(p=>({...p,[s]:e}));return!e};const n=()=>{if(!v())return;s===steps.length-1?onComplete?.():setS(x=>x+1)};const b=()=>setS(x=>Math.max(0,x-1));return <div><nav aria-label=\"Progress\"><ol style={{display:\"flex\",listStyle:\"none\",padding:0,gap:\"8px\"}}>{steps.map((st,i)=><li key={i}><span aria-current={i===s?\"step\":undefined} style={{display:\"flex\",alignItems:\"center\",gap:\"6px\"}}><span style={{width:\"30px\",height:\"30px\",borderRadius:\"50%\",display:\"inline-flex\",alignItems:\"center\",justifyContent:\"center\",background:i<s?\"#4caf50\":i===s?\"#1976d2\":\"#e0e0e0\",color:\"#fff\",fontWeight:600,fontSize:\"0.85rem\"}}>{i<s?\"\u2713\":i+1}</span><span style={{fontSize:\"0.9rem\"}}>{st.label}</span></span></li>)}</ol></nav><div>{steps[s].content}</div>{errs[s]&&<div role=\"alert\" style={{color:\"#d32f2f\",margin:\"8px 0\"}}>{errs[s]}</div>}<div style={{display:\"flex\",justifyContent:\"space-between\",marginTop:\"20px\"}}><button onClick={b} disabled={s===0}>Back</button>{s<steps.length-1?<button onClick={n}>Next</button>:<button onClick={n}>Submit</button>}</div></div>}", null, "high"]], 90]]