[["pagination", "Build accessible pagination with page numbers and prev/next", [["c-nav", "Prev/Next and direct clicks", 0.4], ["c-cur", "Current page indicated", 0.3], ["c-aria", "Navigation role and labels", 0.3]], [["function @N@({page,total,setPage}){return <div><button onClick={()=>setPage(page-1)}>Prev</button>{Array.from({length:total},(_,i)=><button key={i} onClick={()=>setPage(i+1)}>{i+1}</button>)}<button onClick={()=>setPage(page+1)}>Next</button></div>}", "No disabled state; no ARIA; no ellipsis; no aria-current", "function @N@({page,total,setPage}){const ps=[];for(let i=1;i<=total;i++){if(i===1||i===total||(i>=page-1&&i<=page+1))ps.push(i);else if(ps[ps.length-1]!==-1)ps.push(-1)}return <nav role=\"navigation\" aria-label=\"Pagination\"><ul style={{display:\"flex\",listStyle:\"none\",padding:0,gap:\"4px\"}}><li><button onClick={()=>setPage(page-1)} disabled={page<=1}>Prev</button></li>{ps.map((p,i)=>p===-1?<li key={\"e-\"+i}><span>...</span></li>:<li key={p}><button onClick={()=>setPage(p)} aria-current={p===page?\"page\":undefined} style={{padding:\"6px 12px\",border:\"1px solid #ddd\",borderRadius:\"4px\",background:p===page?\"#1976d2\":\"#fff\",color:p===page?\"#fff\":\"#333\",cursor:\"pointer\"}}>{p}</button></li>)}<li><button onClick={()=>setPage(page+1)} disabled={page>=total}>Next</button></li></ul></nav>}", null, "high"]], 95]]