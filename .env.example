# ═══════════════════════════════════════════════════════════════════════════════
#  ShipToPod — environment configuration
# ═══════════════════════════════════════════════════════════════════════════════
#  Copy to .env.local and fill in the values.
#  Keys marked [REQUIRED] must be set for the loop to run end-to-end.
#  Keys marked [OPTIONAL] have sensible defaults or disable features when unset.

# ── DeepSeek (teacher / strong solver) ──────────────────────────────────────
# [REQUIRED] Your DeepSeek API key from https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
# [OPTIONAL] Override the API base URL (default: https://api.deepseek.com)
DEEPSEEK_BASE_URL=https://api.deepseek.com
# [OPTIONAL] Teacher model to use for writing fixes (default: deepseek-reasoner)
DEEPSEEK_TEACHER_MODEL=deepseek-reasoner

# ── Student (weak solver + fine-tune target) ─────────────────────────────────
# [REQUIRED] The small model to draft solutions and LoRA-train.
# Run via vLLM on a RunPod pod, RunPod Flash serverless, or a local GPU,
# then point STUDENT_BASE_URL at its OpenAI-compatible endpoint.
STUDENT_MODEL=deepseek-ai/deepseek-coder-1.3b-instruct
# [REQUIRED for live runs] vLLM / RunPod Flash inference endpoint URL
STUDENT_BASE_URL=
# [OPTIONAL] API key if your inference endpoint requires auth
STUDENT_API_KEY=
# [OPTIONAL] Inference backend: vllm (default), runpod-flash, or local
STUDENT_PROVIDER=vllm

# ── RunPod GPU Cloud (LoRA training — replaces Prime Intellect) ──────────────
# [REQUIRED] Your RunPod API key from https://www.runpod.io/console/user/settings
RUNPOD_API_KEY=
# [OPTIONAL] Path to runpodctl executable if not in PATH
RUNPODCTL_PATH=
# [OPTIONAL] Training backend: runpod (default) or prime (legacy)
BBB_TRAINING_PROVIDER=runpod

# ── RunPod Flash (serverless student inference — alternative to dedicated pod) ──
# To offload student inference to serverless, set STUDENT_PROVIDER=runpod-flash
# and configure STUDENT_BASE_URL to your RunPod Flash endpoint.
# No separate RUNPOD_FLASH_* keys needed; the engine speaks OpenAI-compatible API.

# ── Prime Intellect (legacy — only used when BBB_TRAINING_PROVIDER=prime) ────
# [OPTIONAL] Only needed if using Prime instead of RunPod for training
PRIME_API_KEY=
# [OPTIONAL] Force a specific GPU type id on Prime (auto-selected if unset)
PRIME_GPU_ID=
# [OPTIONAL] Path to the SSH private key registered with Prime
PRIME_SSH_KEY_PATH=

# ── Hugging Face (model download + per-run adapter push) ─────────────────────
# [REQUIRED] Hugging Face token with read access to gated models
HF_TOKEN=
# [OPTIONAL] A NEW private repo is created on HF Hub for every fine-tuning run,
# named "<prefix>-<runId>". Unset to skip push (adapter stays on the pod).
BBB_HF_HUB_REPO=
# [OPTIONAL] Max training steps (default: epoch-based, roughly 20). Override
# for quick smoke tests or extra-long runs.
BBB_TRAINING_MAX_STEPS=20
# [OPTIONAL] Number of training epochs (default: 3)
BBB_TRAINING_EPOCHS=3
# [OPTIONAL] Base model for LoRA training (default: deepseek-coder-1.3b)
BBB_MODEL_ID=deepseek-ai/deepseek-coder-1.3b-instruct

# ── Local embeddings (diversity gate — no external API needed) ───────────────
# [OPTIONAL] Embedding model for cosine-similarity diversity filtering
EMBED_MODEL=BAAI/bge-small-en-v1.5

# ── Code-execution runners (the auditor) ────────────────────────────────────
# [OPTIONAL] Timeout per test run in milliseconds (default: 10_000)
PYTHON_RUNNER_TIMEOUT_MS=10000
# [OPTIONAL] Allow network access in the sandbox (default: 0 = off)
PYTHON_RUNNER_ALLOW_NETWORK=0

# ── Benchmark task sources ──────────────────────────────────────────────────
# [OPTIONAL] Comma-separated dataset names (default: mbpp,humaneval,spider)
TASK_DATASETS=mbpp,humaneval,spider
# [OPTIONAL] Fraction of tasks held out for evaluation (default: 0.2)
TASK_EVAL_HOLDOUT_FRACTION=0.2

# ── MongoDB Atlas (run / pair / event persistence) ───────────────────────────
# [OPTIONAL] Loop runs without persistence when unset (degraded-but-not-broken)
MONGODB_ATLAS_URI=
# [OPTIONAL] Database name (default: shiptopod)
MONGODB_DB_NAME=shiptopod

# ── Bright Data (optional task augmentation) ─────────────────────────────────
# [OPTIONAL] Bright Data Web Unlocker API key for scraping coding sites
BRIGHTDATA_API_KEY=
# [OPTIONAL] Bright Data zone name (default: "unlocker" — check your dashboard)
BRIGHTDATA_ZONE=unlocker

# ── Remote pod config ───────────────────────────────────────────────────────
# [OPTIONAL] Remote working directory on GPU pods (default: /workspace)
BBB_REMOTE_ROOT=/workspace

# ── Demo mode (deterministic stub loops for e2e / CI) ────────────────────────
# [OPTIONAL] Set to 1 to run fully stubbed demo loops (no API calls, no GPUs)
BBB_DEMO_MODE=0

# ── Next.js public vars (exposed to browser) ─────────────────────────────────
# [OPTIONAL] Public URI prefix for training bucket / assets
NEXT_PUBLIC_TRAINING_BUCKET_URI=
