# --- DeepSeek (teacher / strong solver, and optional adversarial task augmentation) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TEACHER_MODEL=deepseek-reasoner

# --- Student (weak solver + fine-tune target): a small DeepSeek-Coder served via vLLM ---
# Run the base model (then the LoRA-merged model) on a Prime pod or a local GPU and point
# STUDENT_BASE_URL at its OpenAI-compatible endpoint.
STUDENT_MODEL=deepseek-ai/deepseek-coder-1.3b-instruct
STUDENT_BASE_URL=
STUDENT_API_KEY=

# --- Local embeddings (diversity gate; no external API) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Code-execution runners (the auditor) ---
PYTHON_RUNNER_TIMEOUT_MS=10000
PYTHON_RUNNER_ALLOW_NETWORK=0

# --- Benchmark task sources (seed pools; held-out split is carved off automatically) ---
TASK_DATASETS=mbpp,humaneval,spider
TASK_EVAL_HOLDOUT_FRACTION=0.2

# --- Prime Intellect (LoRA training on GPU nodes, via the `prime` CLI) ---
PRIME_API_KEY=
PRIME_GPU_ID=
PRIME_SSH_KEY_PATH=
NEXT_PUBLIC_TRAINING_BUCKET_URI=

# --- Hugging Face (student download + per-run adapter push) ---
HF_TOKEN=
# A NEW repo is created for every fine-tuning run, named "<prefix>-<runId>".
STP_HF_HUB_REPO_PREFIX=shiptopod-deepseek-coder
STP_TRAINING_MAX_STEPS=20

# --- MongoDB Atlas (loop run / pair / event persistence) ---
MONGODB_ATLAS_URI=
MONGODB_DB_NAME=shiptopod

# --- Demo mode (deterministic stub loops for e2e/CI; 0 = live) ---
STP_DEMO_MODE=0
